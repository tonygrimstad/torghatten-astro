---
import { getFeatureUrl, getFeatureText } from "../config/siteConfig.ts";
import { useTranslations } from "../utils/useTranslations.ts";

const { t } = useTranslations(Astro.url);

// Hent live scroll URL og tekst fra feature toggle
const liveScrollUrl = getFeatureUrl("liveScroll");
const liveScrollTitle = getFeatureText("liveScroll") || t("liveScroll.title");
---

{liveScrollUrl && (
  <section class="py-12 bg-linear-to-r from-green-600 via-emerald-600 to-teal-700">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          🏃‍♂️ {liveScrollTitle}
        </h2>
        <p class="text-xl text-white/90">
          {t("liveScroll.description", "Følg løpet live mens det skjer!")}
        </p>
        <div class="w-24 h-1 bg-yellow-400 mx-auto mt-6"></div>
      </div>

      <!-- Live Scroll iframe -->
      <div class="bg-white rounded-xl shadow-2xl overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <h3 class="font-semibold text-gray-800 flex items-center gap-2">
              <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span>
              {t("liveScroll.live", "LIVE")}
            </h3>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <img
                src="/images/logos/EQ-Timing-logo.png"
                alt="EQ Timing logo"
                class="h-5 w-auto"
              />
              <span>EQ Timing</span>
            </div>
          </div>
        </div>

        <div class="relative">
          <iframe
            id="livescroll-iframe"
            src={liveScrollUrl}
            class="w-full border-0 block"
            style="height: 1200px"
            title={liveScrollTitle}
            allow="fullscreen"
          ></iframe>

          <!-- Fallback for loading -->
          <div class="absolute inset-0 flex items-center justify-center bg-gray-100 animate-pulse" id="iframe-loading">
            <div class="text-center">
              <div class="animate-spin w-8 h-8 border-4 border-green-500 border-t-transparent rounded-full mx-auto mb-4"></div>
              <p class="text-gray-600">{t("liveScroll.loading", "Laster live resultater...")}</p>
            </div>
          </div>
        </div>

        <!-- Info footer -->
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
          <p class="text-sm text-gray-600 text-center">
            {t("liveScroll.refreshInfo", "Resultatene oppdateres automatisk. Ingen behov for å laste siden på nytt.")}
          </p>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  // Skjul loading-overlay når iframe er lastet
  const iframe = document.getElementById('livescroll-iframe') as HTMLIFrameElement | null;
  const loading = document.getElementById('iframe-loading');

  if (iframe && loading) {
    iframe.addEventListener('load', () => {
      loading.style.display = 'none';
    });

    // Timeout fallback i tilfelle load event ikke fyrer
    setTimeout(() => {
      loading.style.display = 'none';
    }, 3000);
  }

  // Dynamisk høyde via postMessage (fungerer hvis EQ Timing sender resize-events)
  window.addEventListener('message', (event) => {
    if (!iframe) return;
    // Aksepter kun meldinger fra EQ Timing
    if (!event.origin.includes('eqtiming.com')) return;

    const data = event.data as unknown;
    if (typeof data === 'object' && data !== null) {
      const msg = data as Record<string, unknown>;
      // Vanlige postMessage-formater for iframe-resize
      const height =
        typeof msg['height'] === 'number' ? msg['height'] :
        typeof msg['frameHeight'] === 'number' ? msg['frameHeight'] :
        typeof msg['scrollHeight'] === 'number' ? msg['scrollHeight'] :
        null;

      if (height && height > 200) {
        iframe.style.height = `${height}px`;
      }
    }
  });
</script>
