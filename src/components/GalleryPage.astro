---
import { getImage } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import LightboxGallery from "../components/LightboxGallery.astro";
import { galleriData } from "../data/galleriIndex";
import { useTranslations } from "../utils/useTranslations.ts";

// Import gallery hero images
import hero1 from "../assets/gallery-hero/cropped-torghatten20150217-1.jpg";
import hero2 from "../assets/gallery-hero/cropped-i-SmkP5Tb.jpg";
import hero3 from "../assets/gallery-hero/cropped-20150502torgattenmaraton-34.jpg";
import hero4 from "../assets/gallery-hero/cropped-20150502torgattenmaraton-21.jpg";
import hero5 from "../assets/gallery-hero/cropped-i-j4tV97J.jpg";
import hero6 from "../assets/gallery-hero/30mai-TorghattenMaraton-9721.jpg";
import hero7 from "../assets/gallery-hero/30mai-TorghattenMaraton-9712.jpg";
import hero8 from "../assets/gallery-hero/30mai-TorghattenMaraton-9095.jpg";

const { t, currentLang } = useTranslations(Astro.url);
const sortedYears = [...galleriData].sort((a, b) => b.year - a.year);

// Generate optimized URLs for all hero images (for runtime random selection)
const optimizedHero1 = await getImage({
  src: hero1,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero2 = await getImage({
  src: hero2,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero3 = await getImage({
  src: hero3,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero4 = await getImage({
  src: hero4,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero5 = await getImage({
  src: hero5,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero6 = await getImage({
  src: hero6,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero7 = await getImage({
  src: hero7,
  width: 1280,
  format: "webp",
  quality: 85,
});
const optimizedHero8 = await getImage({
  src: hero8,
  width: 1280,
  format: "webp",
  quality: 85,
});

const heroUrls = [
  optimizedHero1.src,
  optimizedHero2.src,
  optimizedHero3.src,
  optimizedHero4.src,
  optimizedHero5.src,
  optimizedHero6.src,
  optimizedHero7.src,
  optimizedHero8.src,
];

// Use translated SEO titles
const title = t("seo.galleryTitle");
const description = t("seo.galleryDescription");
---

<Layout title={title} description={description} lang={currentLang}>
  <!-- Modern Hero Section for Gallery with Optimized Background -->
  <section
    id="gallery-hero"
    class="relative min-h-[60vh] md:min-h-[70vh] flex items-center justify-center text-white mt-20 md:mt-24"
  >
    <!-- Gradient Overlay -->
    <div
      class="absolute inset-0 bg-linear-to-br from-purple-900/80 via-indigo-800/70 to-blue-700/80"
    >
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6 py-16">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 drop-shadow-lg">
        {t("gallery.modernTitle", "Øyeblikk fra Løpet")}
      </h1>
      <p
        class="text-xl md:text-2xl opacity-95 mb-8 max-w-3xl mx-auto drop-shadow-md"
      >
        {
          t(
            "gallery.subtitle",
            "Se tilbake på magiske øyeblikk fra Torghatten Maraton gjennom årene",
          )
        }
      </p>
      <div class="w-32 h-1 bg-yellow-400 mx-auto shadow-lg"></div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce"
    >
      <svg
        class="w-6 h-6 text-white/80"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <script define:vars={{ heroUrls }}>
    // Random hero selection at RUNTIME (per page visit)
    document.addEventListener("DOMContentLoaded", () => {
      const heroSection = document.getElementById("gallery-hero");
      if (heroSection && heroUrls && heroUrls.length > 0) {
        const randomUrl = heroUrls[Math.floor(Math.random() * heroUrls.length)];
        heroSection.style.backgroundImage = `url('${randomUrl}')`;
        heroSection.style.backgroundSize = "cover";
        heroSection.style.backgroundPosition = "center";
        heroSection.style.backgroundAttachment = "fixed";
      }
    });
  </script>

  <!-- Sticky Navigation Section -->
  <section
    class="bg-white/95 backdrop-blur-sm py-6 border-b border-gray-200 sticky top-20 md:top-24 z-40 shadow-lg"
  >
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <span
            class="text-gray-700 font-semibold text-sm sm:text-base flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-purple-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            {t("gallery.selectYear", "Velg år:")}
          </span>
          <select
            id="yearFilter"
            aria-label={t("gallery.selectYear", "Velg år:")}
            class="bg-white border border-gray-300 text-gray-800 px-4 py-2 rounded-xl shadow-sm hover:border-purple-500 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-all text-sm font-medium"
          >
            {
              sortedYears.map((g) => (
                <option value={`year-${g.year}`}>{g.year}</option>
              ))
            }
          </select>
        </div>
        <div
          class="flex items-center gap-2 text-xs sm:text-sm text-gray-600 bg-gray-100 px-3 py-2 rounded-lg"
        >
          <svg
            class="w-4 h-4 text-purple-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          <span id="photoCounter" class="font-medium">
            {sortedYears[0].photos.length}
            {t("gallery.photoCount", "bilder totalt")}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Content -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6" id="galleryContainer">
      {
        // Rendre kun siste år som default
        sortedYears.slice(0, 1).map((entry) => (
          <div
            class="gallery-year mb-16"
            data-year={`year-${entry.year}`}
            data-photo-count={entry.photos.length}
          >
            <LightboxGallery
              year={entry.year}
              photos={entry.photos}
              photographers={entry.photographers || []}
            />
          </div>
        ))
      }
    </div>
  </section>
  <script define:vars={{ galleriData: sortedYears }}>
    document.addEventListener("DOMContentLoaded", () => {
      const select = document.getElementById("yearFilter");
      const counter = document.getElementById("photoCounter");
      const galleryContainer = document.getElementById("galleryContainer");
      const counterText =
        counter && counter.textContent
          ? counter.textContent.split(" ").slice(-2).join(" ")
          : "bilder totalt";

      // Funksjon for å rendre galleri for valgt år
      function renderGallery(year) {
        if (!galleryContainer) return;

        const yearData = galleriData.find((g) => g.year === year);
        if (!yearData) return;

        // Oppdater counter
        if (counter) {
          counter.textContent = `${yearData.photos.length} ${counterText}`;
        }

        // Rendre bilder
        const photographerNames = yearData.photographers
          ? yearData.photographers.map((p) => p.name).join(", ")
          : "";

        let html = `
              <div class="gallery-year mb-16" data-year="year-${year}" data-photo-count="${yearData.photos.length}">
                <div class="mb-12">
                  <div class="mb-6">
                    <h2 class="text-2xl font-bold text-gray-800 mb-3 flex items-center gap-2">
                      <span class="text-blue-600">📅</span>
                      ${year}
                    </h2>`;

        if (yearData.photographers && yearData.photographers.length > 0) {
          html += `
                    <div class="flex flex-wrap items-center gap-2 text-sm">
                      <span class="text-gray-600">📸 Fotografer:</span>`;

          yearData.photographers.forEach((photographer, index) => {
            html += `<span class="inline-flex items-center">`;
            if (photographer.url) {
              html += `<a href="${photographer.url}" class="text-blue-600 hover:text-blue-800 hover:underline font-medium" target="_blank" rel="noopener noreferrer">${photographer.name}</a>`;
            } else {
              html += `<span class="text-gray-700 font-medium">${photographer.name}</span>`;
            }
            if (index < yearData.photographers.length - 1) {
              html += `<span class="mx-1 text-gray-400">•</span>`;
            }
            html += `</span>`;
          });

          html += `
                    </div>`;
        }

        html += `
                  </div>
                  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">`;

        yearData.photos.forEach((url, i) => {
          const altText = photographerNames
            ? `Torghatten Maraton ${year} - Bilde ${i + 1} av ${yearData.photos.length} (Fotograf: ${photographerNames})`
            : `Torghatten Maraton ${year} - Bilde ${i + 1} av ${yearData.photos.length}`;

          const ariaLabel = `${altText} - Bilde ${i + 1}`;

          html += `
                    <div class="group relative overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-all duration-300">
                      <a
                        href="${url.replace("/w_800/", "/w_1600/")}"
                        data-fslightbox="gallery-${year}"
                        aria-label="${ariaLabel}"
                      >
                        <img
                          src="${url}"
                          class="w-full h-48 object-cover cursor-pointer transition-transform duration-300 group-hover:scale-110"
                          alt="${altText}"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-center justify-center">
                          <div class="text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </svg>
                          </div>
                        </div>
                      </a>
                    </div>`;
        });

        html += `
                  </div>
                </div>
              </div>`;

        galleryContainer.innerHTML = html;

        // Refresh lightbox (hvis det brukes fslightbox)
        if (window.refreshFsLightbox) {
          window.refreshFsLightbox();
        }
      }

      // Bytt år når select endres
      if (select && select instanceof HTMLSelectElement) {
        select.addEventListener("change", () => {
          const val = select.value;
          if (val.startsWith("year-")) {
            const year = parseInt(val.replace("year-", ""));
            renderGallery(year);
          }
        });
      }
    });
  </script>
</Layout>
